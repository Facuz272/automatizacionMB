GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
SENDER_EMAIL=your-sender-address@gmail.com
SENDER_APP_PASSWORD=YOUR_GMAIL_APP_PASSWORD_HERE
APOLLO_API_KEY=YOUR_APOLLO_API_KEY_HERE

# Optional — dead-man's-switch. Pipeline pings this on each run; if pings stop,
# Healthchecks.io alerts you. Leave unset to disable.
HEALTHCHECK_PING_URL=
# Optional — directory for the rotating pipeline.log (default: logs)
LOG_DIR=logs
# Optional — when a domain has no decision-maker (Apollo) and no personal email,
# fall back to a single human-read generic inbox (info@, office@…). Right for
# micro-business outreach; set to false for strict decision-maker-only mode.
# Bounce/trap inboxes (noreply@, postmaster@…) are never used. Default: true.
ALLOW_GENERIC_FALLBACK=true